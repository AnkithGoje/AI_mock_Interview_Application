# LiveKit API Keys (Required for both Backend and Frontend if using cloud)
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# LiveKit URL (Required for Frontend)
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud

# Backend URL (Required for Frontend to fetch tokens)
# For local development: http://localhost:5000
# For production: https://your-backend-app.railway.app
VITE_BACKEND_URL=http://localhost:5000

# Backend Port (Optional, default 5000)
PORT=5000

# STT/TTS Providers (Required for Agent)
DEEPGRAM_API_KEY=your_deepgram_key
GROQ_API_KEY=your_groq_key
OPENAI_API_KEY=your_openai_key
